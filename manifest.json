{
  "manifest_version": 3,
  "name": "Job App Autofill",
  "version": "0.2.0",
  "description": "Autofills job application forms from your saved profile and can upload your resume.",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_title": "Job App Autofill",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
